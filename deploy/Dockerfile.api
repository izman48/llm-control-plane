# Control-plane API (FastAPI gateway over sim workers). Runtime deps only —
# no dev tools, no torch/transformers (the realmodel extra is host-native).
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1
RUN pip install --no-cache-dir uv

WORKDIR /app
COPY pyproject.toml uv.lock README.md ./
COPY src ./src
RUN uv sync --frozen

EXPOSE 8000
CMD ["uv", "run", "--no-sync", "uvicorn", "inference_demo.gateway.app:app", \
     "--host", "0.0.0.0", "--port", "8000"]
