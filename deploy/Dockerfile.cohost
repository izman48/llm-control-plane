# Single container for co-hosting behind an existing reverse proxy: builds the
# console and serves it AND the API from one uvicorn process (no second Caddy).
FROM node:20-slim AS ui
WORKDIR /ui
COPY ui/package.json ui/package-lock.json ./
RUN npm ci
COPY ui/ ./
RUN npm run build

FROM python:3.12-slim
ENV PYTHONUNBUFFERED=1 UI_DIST=/app/ui_dist
RUN pip install --no-cache-dir uv

WORKDIR /app
COPY pyproject.toml uv.lock README.md ./
COPY src ./src
RUN uv sync --frozen
COPY --from=ui /ui/dist /app/ui_dist

EXPOSE 8000
CMD ["uv", "run", "--no-sync", "uvicorn", "inference_demo.gateway.app:app", \
     "--host", "0.0.0.0", "--port", "8000"]
